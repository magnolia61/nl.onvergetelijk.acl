        wachthond($extdebug,9, 'result_groupcontact_hoofd_get',     $result_hoofd_get);

        $group_hoofd_count    = $result_hoofd_get->countMatched();
        wachthond($extdebug,3, 'group_hoofd_count',   $group_hoofd_count);

        if ($group_hoofd_count == 1) {

            $group_hoofd_status   = $result_hoofd_get[0]['status'] ?? NULL;
            $group_hoofd_label    = $result_hoofd_get[0]['group_id:label'] ?? NULL;     
            wachthond($extdebug,1, 'group_hoofd_status',  $group_hoofd_status);

            if ($group_hoofd_status == 'Added' OR $group_hoofd_status == 'Removed') {
                $group_hoofd = 1;
                wachthond($extdebug,1, 'deel van ACL groep',$group_hoofd_label);
            }
        }

        if ($group_staf == 1 AND $group_hoofd == 0 AND $ditjaarleidyes == 1 AND in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding'))) {

            wachthond($extdebug,2, "########################################################################");
            wachthond($extdebug,1, "### ACL 4.2 INDIEN IN KAMPSTAF EN HOOFDLEIDING VOEG DAN OOK TOE AAN ACL GROEP HOOFDLEIDING");
            wachthond($extdebug,2, "########################################################################");

            $ditjaarhoofdyes = 1;

            $params_groupcontact_hoofd_create = [
                'checkPermissions' => FALSE,
                'debug' => $apidebug,
                'values' => [
                    'group_id'    => $aclgrouphoofd, 
                    'contact_id'  => $contact_id,
                    'status'    => 'Added',
                ],
            ];
            wachthond($extdebug,7, 'params_groupcontact_hoofd_create', $params_groupcontact_hoofd_create);
            if ($extwrite == 1 AND $aclgrouphoofd) {
                $result_groupcontact_hoofd_create = civicrm_api4('GroupContact', 'create', $params_groupcontact_hoofd_create);
                wachthond($extdebug,9, 'result_groupcontact_hoofd_create', $result_groupcontact_hoofd_create);
                wachthond($extdebug,1, 'Toegevoegd aan ACL groep',  $group_hoofd_label);

                ####################################################
                # CHANGE CORRESPONDING DRUPAL ROLE FOR USER
                ####################################################
                if ($valid_drupalid) {
                    $rol_cms_hoofd    = "ditjaar_hoofdleiding";
                    $drupal_role_change = drupal_role_change($valid_drupalid, $rol_cms_hoofd, 'ADD');
                } else { 
                    wachthond($extdebug,1, "GEEN WAARDE VOOR VALID DRUPALID", $valid_drupalid);
                }
                ####################################################
            }
        }

        if ($group_staf == 1 AND $group_hoofd == 1 AND $ditjaarleidyes == 1 AND in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding'))) {

            wachthond($extdebug,2, "########################################################################");
            wachthond($extdebug,1, "### ACL 4.3 INDIEN IN KAMPSTAF EN (WEER) HOOFDLEIDING VOEG DAN OOK TOE AAN ACL GROEP HOOFDLEIDING");
            wachthond($extdebug,2, "########################################################################");

            $ditjaarhoofdyes = 1;

            $params_groupcontact_hoofd_update = [
                'checkPermissions' => FALSE,
                'debug' => $apidebug,
                'values' => [
                    'status' => 'Added',
                ],
                'where' => [
                    ['group_id',  '=', $aclgrouphoofd], 
                    ['contact_id',  '=', $contact_id],
                ],
            ];
            wachthond($extdebug,7, 'params_groupcontact_hoofd_update', $params_groupcontact_hoofd_update);
            if ($extwrite == 1 AND $aclgrouphoofd) {
                $result_groupcontact_hoofd_update = civicrm_api4('GroupContact', 'update', $params_groupcontact_hoofd_update);
                wachthond($extdebug,9, 'result_groupcontact_hoofd_update', $result_groupcontact_hoofd_update);
                wachthond($extdebug,1, 'Weer toegevoegd aan ACL groep', $group_hoofd_label);

                ####################################################
                # CHANGE CORRESPONDING DRUPAL ROLE FOR USER
                ####################################################
                if ($valid_drupalid) {
                      $rol_cms_hoofd    = "ditjaar_hoofdleiding";
                      $drupal_role_change = drupal_role_change($valid_drupalid, $rol_cms_hoofd, 'ADD');
                      wachthond($extdebug,1, 'Drupal role aangepast',       $drupal_role_change);
                } else {
                      wachthond($extdebug,1, "GEEN WAARDE VOOR VALID DRUPALID", $valid_drupalid);
                }
                ####################################################
            }
        }

        if ($group_staf == 0 OR (!in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding'))) OR $ditjaarleidnot == 1) {

            wachthond($extdebug,2, "########################################################################");
            wachthond($extdebug,1, "### ACL 4.4 INDIEN NIET IN KAMPSTAF EN GEEN HOOFDLEIDING VERWIJDER DAN OOK UIT ACL GROEP HOOFDLEIDING");
            wachthond($extdebug,2, "########################################################################");

            $ditjaarhoofdyes = 0;

            $params_groupcontact_hoofd_remove = [
                'checkPermissions' => FALSE,
                'debug' => $apidebug,
                'values' => [
                    'status' => 'Removed',
                ],
                'where' => [
                    ['group_id',  '=', $aclgrouphoofd], 
                    ['contact_id',  '=', $contact_id],
                ],
            ];
            wachthond($extdebug,7, 'params_groupcontact_hoofd_remove', $params_groupcontact_hoofd_remove);
            if ($extwrite == 1 AND $aclgrouphoofd) {
                $result_groupcontact_hoofd_remove = civicrm_api4('GroupContact', 'update', $params_groupcontact_hoofd_remove);
                wachthond($extdebug,9, 'result_groupcontact_hoofd_remove',  $result_groupcontact_hoofd_remove);
                wachthond($extdebug,1, 'Verwijderd uit ACL groep',      $group_hoofd_label);

                ####################################################
                # CHANGE CORRESPONDING DRUPAL ROLE FOR USER
                ####################################################
                $rol_cms_hoofd    = "ditjaar_hoofdleiding";
                $drupal_role_change = drupal_role_change($valid_drupalid, $rol_cms_hoofd, 'REMOVE');
                wachthond($extdebug,1, 'Drupal role aangepast',       $drupal_role_change);
                ####################################################
            }
        }
    }

    if (in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding','kernteamlid','bestuurslid','kampstaf'))) {

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### ACL 5.1 REGISTER HOOFDLEIDING VOOR FUTURE KAMPSTAF EVENTS", "$displayname ($ditjaar_pos_leid_kampfunctie)");
        wachthond($extdebug,2, "########################################################################");

        // M61: DISABLE FOR NOW (123)

        if ($group_staf == 123 AND $group_kamp == 1 AND $ditjaarleidyes == 1 AND in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding','bestuurslid','kampstaf'))) {

            ##########################################################################################
            # RETREIVE EVENT ID'S FROM CACHE
            ##########################################################################################
            $kampids_meet       = Civi::cache()->get('cache_kampids_meet');
            wachthond($extdebug,3, 'kampids_meet',          $kampids_meet);     

            # REGISTREER ALLEEN DE EVENT IDS DIE NOG NIET GEREGISTREERD ZIJN
            $evtcv_meet_notregistered_array = array_diff($kampids_meet, $evtcv_meet_array);
            arsort($evtcv_meet_notregistered_array); // sort by value (reverse)

            wachthond($extdebug,1, "evtcv_meet_array",                  $evtcv_meet_array);
            wachthond($extdebug,1, "kampids_meet",                      $kampids_meet);
            wachthond($extdebug,1, "evtcv_meet_notregistered_array",    $evtcv_meet_notregistered_array);

            wachthond($extdebug,1, "ditevent_part_functie",             $ditjaar_pos_leid_kampfunctie);
            wachthond($extdebug,1, "group_staf",                        $group_staf);

            if (in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding','bestuurslid','kampstaf')) AND $group_staf == 1) {

                // ALLEEN INDIEN HL & IN MANUAL ACL GROUP STAF

                foreach ($evtcv_meet_notregistered_array as $kampstafeid) {
                    $params_part_ditevent_create = [
                        'checkPermissions' => FALSE,
                        'debug' => $apidebug,
                        'values' => [
                            'contact_id'        => $contact_id,
                            'event_id'          => $kampstafeid,
                            'register_date'     => $today_datetime,
                            'status_id'         => 24,  // initiele status: nog niet bekend   
                            'role_id'           => [6], // rol = leiding
                        ],
                    ];
                    wachthond($extdebug,7, 'params_participant_create',                       $params_part_ditevent_create);
                    if ($regpast == 1 AND $kampstafeid > 0) {
                        $result_participant_create = civicrm_api4('Participant','create',   $params_part_ditevent_create);
                    }
                    wachthond($extdebug,3, "Deze persoon geregistreerd kampstaf eventid", $kampstafeid);
                    wachthond($extdebug,9, 'result_participant_create', $result_participant_create);
                }
            }
        }

        wachthond($extdebug,3, 'group_staf',      $group_staf);
        wachthond($extdebug,3, 'group_kamp',      $group_kamp);
        wachthond($extdebug,3, 'ditjaarleidyes', $ditjaarleidyes);
        wachthond($extdebug,3, 'ditevent_part_functie', $ditjaar_pos_leid_kampfunctie);
    }

    if ($group_staf == 1 AND $group_kamp == 1 AND $ditjaarleidyes == 1 AND in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding','kernteamlid','bestuurslid','kampstaf'))) {

            wachthond($extdebug,2, "########################################################################");
            wachthond($extdebug,1, "### ACL 6.1 VOEG HOOFDLEIDING EMAIL TOE AAN GROEP DIE KAMPSTAF EMAIL ONTVANGT", "$displayname ($ditjaar_pos_leid_kampfunctie)");
            wachthond($extdebug,2, "########################################################################");
            ##########################################################################################
            // M61: BIJ 3.3 IS ALLES MET DEFAULT WAARDEN AANGEMAAKT. HIER WORDT ALLES AANGEPAST NAV VOORKEUREN
            ##########################################################################################  
        /*
            ##########################################################################################  
            // M61: FIRST DELETE EXISTING NOTIF EMAILS (BECAUSE DOUBLES WERE CREATED: THIS SHOULD NOT HAPPEN > TODO)
            ##########################################################################################  

            $result_email_notif_delete = civicrm_api4('Email', 'delete', [
                'where' => [
                    ['location_type_id', 'IN', [16, 17, 18, 19]],
                    ['contact_id', '=', $contact_id],
                  ],
            ]);
        */
            wachthond($extdebug,3, 'email_home_id',   $email_home_id);
            wachthond($extdebug,3, 'email_othr_id',   $email_othr_id);
            wachthond($extdebug,3, 'email_priv_id',   $email_priv_id);
            wachthond($extdebug,3, 'email_deel_id',   $notif_deel_id);
            wachthond($extdebug,3, 'email_leid_id',   $notif_leid_id);
            wachthond($extdebug,3, 'email_kamp_id',   $notif_kamp_id);
            wachthond($extdebug,3, 'email_staf_id',   $notif_staf_id);

            wachthond($extdebug,3, 'email_home_email',  $email_home_email);
            wachthond($extdebug,3, 'email_othr_email',  $email_othr_email);
            wachthond($extdebug,3, 'email_priv_email',  $email_priv_email);
            wachthond($extdebug,3, 'notif_deel_email',  $notif_deel_email);
            wachthond($extdebug,3, 'notif_leid_email',  $notif_leid_email);
            wachthond($extdebug,3, 'notif_kamp_email',  $notif_kamp_email);
            wachthond($extdebug,3, 'notif_staf_email',  $notif_staf_email);

            wachthond($extdebug,3, 'cont_notificatie_deel',   $cont_notificatie_deel);
            wachthond($extdebug,3, 'cont_notificatie_leid',   $cont_notificatie_leid);
            wachthond($extdebug,3, 'cont_notificatie_kamp',   $cont_notificatie_kamp);
            wachthond($extdebug,3, 'cont_notificatie_staf',   $cont_notificatie_staf);

            wachthond($extdebug,3, 'part_notificatie_deel',   $ditevent_part_notificatie_deel);
            wachthond($extdebug,3, 'part_notificatie_leid',   $ditevent_part_notificatie_leid);
            wachthond($extdebug,3, 'part_notificatie_kamp',   $ditevent_part_notificatie_kamp);
            wachthond($extdebug,3, 'part_notificatie_staf',   $ditevent_part_notificatie_staf);

            if (!empty($cont_notificatie_deel) AND empty($ditevent_part_notificatie_deel))  { $ditevent_part_notificatie_deel=$cont_notificatie_deel; }
            if (!empty($cont_notificatie_leid) AND empty($ditevent_part_notificatie_leid))  { $ditevent_part_notificatie_leid=$cont_notificatie_leid; }
            if (!empty($cont_notificatie_kamp) AND empty($ditevent_part_notificatie_kamp))  { $ditevent_part_notificatie_kamp=$cont_notificatie_kamp; }
            if (!empty($cont_notificatie_staf) AND empty($ditevent_part_notificatie_staf))  { $ditevent_part_notificatie_staf=$cont_notificatie_staf; }

            if (empty($email_priv_email)) {
                $email_priv_email = $email_home_email;
            }

            if ($ditevent_part_notificatie_deel == 'kampmail') {
                $notif_deel_new     = NULL;             # ALLEEN IN DE MAILBOX VAN JOUW KAMP (SWS)
            } elseif ($ditevent_part_notificatie_deel == 'kamppers') {
                $notif_deel_new     = $email_onvr_email;      # OOK OP JOUW PERSOONLIJKE @ONVERGETELIJK
            } elseif ($ditevent_part_notificatie_deel == 'privemail') {
                $notif_deel_new     = $email_priv_email;      # OOK OP JE PRIVE EMAILADRES
            } else {
                $ditevent_part_notificatie_deel = 'privemail'; 
                $notif_deel_new     = $email_priv_email;
            }

            if ($ditevent_part_notificatie_leid == 'kampmail') {
                $notif_leid_new     = NULL;             # ALLEEN IN DE MAILBOX VAN JOUW KAMP (SWS)
            } elseif ($ditevent_part_notificatie_leid == 'kamppers') {
                $notif_leid_new     = $email_onvr_email;      # OOK OP JOUW PERSOONLIJKE @ONVERGETELIJK
            } elseif ($ditevent_part_notificatie_leid == 'privemail') {
                $notif_leid_new     = $email_priv_email;      # OOK OP JE PRIVE EMAILADRES
            } else {
                $ditevent_part_notificatie_leid = 'privemail'; 
                $notif_leid_new     = $email_priv_email;
            }

            if ($ditevent_part_notificatie_kamp == 'kampmail') {
                $notif_kamp_new     = NULL;             # ALLEEN IN DE MAILBOX VAN JOUW KAMP (SWS)
            } elseif ($ditevent_part_notificatie_kamp == 'kamppers') {
                $notif_kamp_new     = $email_onvr_email;      # OOK OP JOUW PERSOONLIJKE @ONVERGETELIJK
            } elseif ($ditevent_part_notificatie_kamp == 'privemail') {
                $notif_kamp_new     = $email_priv_email;      # OOK OP JE PRIVE EMAILADRES
            } else {
                $ditevent_part_notificatie_kamp = 'privemail'; 
                $notif_kamp_new     = $email_priv_email;
            }

            if ($ditevent_part_notificatie_staf == 'kamppers') {
                $notif_staf_new     = $email_onvr_email;      # OOK OP JOUW PERSOONLIJKE @ONVERGETELIJK
            } elseif ($ditevent_part_notificatie_staf == 'privemail') {
                $notif_staf_new     = $email_priv_email;      # OOK OP JE PRIVE EMAILADRES
            } else {
                $ditevent_part_notificatie_staf = 'privemail'; 
                $notif_staf_new     = $email_priv_email;
            }

            ##########################################################################################  
            // M61: CHANGE EMAIL_HOME OP BASIS VAN VOORKEUR NOTIF_STAR
            ##########################################################################################  

            if ($ditevent_part_notificatie_staf AND $notif_staf_new AND in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding','kernteamlid'))) {

                $new_email_home_email = $notif_staf_new; 

                ### EMAIL UPDATE
                if ($email_home_email != $new_email_home_email AND !empty($new_email_home_email)) {
                    $params_email_home_update = [
                        'checkPermissions' => FALSE,
                        'debug' => $apidebug,
                        'where' => [
                            ['id',          '=', $email_home_id],
                            ['contact_id',  '=', $contact_id],
                        ],
                        'values' => [
                            'email'          =>  $new_email_home_email,
                            'location_type_id:name'  =>  "Home",
                            'is_primary'       =>  TRUE,
                        ],
                    ];
                    wachthond($extdebug,7, 'params_email_home_update',        $params_email_home_update);
                    if ($extwrite == 1 AND !in_array($privacy_voorkeuren, array("33","44"))) {
                        $result_email_home_update = civicrm_api4('Email', 'update', $params_email_home_update);
                    }
                    wachthond($extdebug,9, 'result_email_home_update',  $result_email_home_update);
                    wachthond($extdebug,2, 'email_home geupdated',    $new_email_home_email);
                    }
                }

                ##########################################################################################

                wachthond($extdebug,3, 'part_notificatie_deel',   $ditevent_part_notificatie_deel);
                wachthond($extdebug,3, 'part_notificatie_leid',   $ditevent_part_notificatie_leid);
                wachthond($extdebug,3, 'part_notificatie_kamp',   $ditevent_part_notificatie_kamp);
                wachthond($extdebug,3, 'part_notificatie_staf',   $ditevent_part_notificatie_staf);

                wachthond($extdebug,3, 'notif_deel_new',      $notif_deel_new);
                wachthond($extdebug,3, 'notif_leid_new',      $notif_leid_new);
                wachthond($extdebug,3, 'notif_kamp_new',      $notif_kamp_new);
                wachthond($extdebug,3, 'notif_staf_new',      $notif_staf_new);

                //      if ($notif_deel_id AND $notif_deel_email != $notif_deel_new) {
                if ($notif_deel_id > 0) {
                    //M61: Het lukt niet om bij een bestaand email-id het email adres zelf via api te wijzigen. 
                    //M61: Wel via de explorer, niet hier in code. Dus daarom verwijderen en aanmaken
                    $result_email_notif_deel_delete = civicrm_api4('Email', 'delete', [ 'where' => [ 
                        ['location_type_id:label',  '=', 'notif_deel'],
                        ['contact_id',        '=', $contact_id],
                    ],
                ]);
                wachthond($extdebug,3, 'notif_deel verwijderd (tbv opnieuw aanmaken)', $notif_deel_email);
                }

                if ($ditevent_part_notificatie_deel AND $notif_deel_new AND in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding','kernteamlid'))) {
                    $params_email_notif_deel_create = [
                        'checkPermissions' => FALSE,
                        'debug' => $apidebug,
                        'values' => [
                            'location_type_id:name' => 'notif_deel', 
                            'email'   => $notif_deel_new,
                            'contact_id'=> $contact_id, 
                            'is_primary'=> FALSE,
                        ],
                    ];
                    wachthond($extdebug,7, 'params_email_notif_deel_create',        $params_email_notif_deel_create);
                    if ($extwrite == 1 AND !in_array($privacy_voorkeuren, array("33","44"))) {
                        $result_email_notif_deel_create = civicrm_api4('Email', 'create',   $params_email_notif_deel_create);
                        wachthond($extdebug,9, 'result_email_notif_deel_create',      $result_email_notif_deel_create);
                    }
                    wachthond($extdebug,2, 'notif_deel aangemaakt voor', $notif_deel_new);
                }

                //      if ($notif_leid_id AND $notif_leid_email != $notif_leid_new) {
                if ($notif_leid_id > 0) {
                    $result_email_notif_leid_delete = civicrm_api4('Email', 'delete', [ 'where' => [ 
                        ['location_type_id:label',  '=', 'notif_leid'],
                        ['contact_id',              '=', $contact_id],
                    ],
                ]);
                wachthond($extdebug,3, 'notif_leid verwijderd (tbv opnieuw aanmaken)', $notif_leid_email);
                }
                if ($ditevent_part_notificatie_leid AND $notif_leid_new AND in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding','kernteamlid'))) {
                    $params_email_notif_leid_create = [
                        'checkPermissions' => FALSE,
                        'debug' => $apidebug,
                        'values' => [
                            'location_type_id:name' => 'notif_leid', 
                            'email'   => $notif_leid_new,
                            'contact_id'=> $contact_id,
                            'is_primary'=> FALSE,
                        ],
                    ];
                    wachthond($extdebug,7, 'params_email_notif_leid_create',                $params_email_notif_leid_create);
                    if ($extwrite == 1 AND !in_array($privacy_voorkeuren, array("33","44"))) {
                        $result_email_notif_leid_create = civicrm_api4('Email', 'create',   $params_email_notif_leid_create);
                        wachthond($extdebug,9, 'result_email_notif_leid_create',            $result_email_notif_leid_create);
                    }
                    wachthond($extdebug,2, 'notif_leid aangemaakt voor', $notif_leid_new);
                }

                //      if ($notif_kamp_id AND $notif_kamp_email != $notif_kamp_new) {
                if ($notif_kamp_id > 0) {
                    $result_email_notif_kamp_delete = civicrm_api4('Email', 'delete', [ 
                    'where' => [ 
                        ['location_type_id:label',  '=', 'notif_kamp'],
                        ['contact_id',        '=', $contact_id],
                    ],
                ]);
                wachthond($extdebug,3, 'notif_kamp verwijderd (tbv opnieuw aanmaken)', $notif_kamp_email);
                }

                if ($ditevent_part_notificatie_kamp AND $notif_kamp_new AND in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding','kernteamlid'))) {
                    $params_email_notif_kamp_create = [
                        'checkPermissions' => FALSE,
                        'debug' => $apidebug,
                        'values' => [
                            'location_type_id:name' => 'notif_kamp', 
                            'email'   => $notif_kamp_new,
                            'contact_id'=> $contact_id, 
                            'is_primary'=> FALSE,
                        ],
                    ];
                    wachthond($extdebug,7, 'params_email_notif_kamp_create',                $params_email_notif_kamp_create);
                    if ($extwrite == 1 AND !in_array($privacy_voorkeuren, array("33","44"))) {
                        $result_email_notif_kamp_create = civicrm_api4('Email', 'create',   $params_email_notif_kamp_create);
                    wachthond($extdebug,9, 'result_email_notif_kamp_create',               $result_email_notif_kamp_create);         
                    }
                    wachthond($extdebug,2, 'notif_kamp aangemaakt voor', $notif_kamp_new);
                }

                if ($notif_staf_id > 0) {
                $result_email_notif_staf_delete = civicrm_api4('Email', 'delete', [ 
                  'where' => [
                    ['location_type_id:label',  '=', 'notif_staf'],
                    ['contact_id',        '=', $contact_id],
                  ],
                ]);
                wachthond($extdebug,3, 'notif_staf verwijderd (tbv opnieuw aanmaken)', $notif_staf_email);
                }
                if ($ditevent_part_notificatie_staf AND $notif_staf_new AND in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding','kernteamlid'))) {
                    $params_email_notif_staf_create = [
                        'checkPermissions' => FALSE,
                        'debug' => $apidebug, 
                        'values' => [
                            'location_type_id:name' => 'notif_staf', 
                            'email'   => $notif_staf_new,
                            'contact_id'=> $contact_id, 
                            'is_primary'=> FALSE,
                        ],
                    ];
                    wachthond($extdebug,7, 'params_email_notif_staf_create',        $params_email_notif_staf_create);
                    if ($extwrite == 1 AND !in_array($privacy_voorkeuren, array("33","44"))) {
                        $result_email_notif_staf_create = civicrm_api4('Email', 'create',   $params_email_notif_staf_create);
                        wachthond($extdebug,9, 'result_email_notif_staf_create',      $result_email_notif_staf_create);
                    }
                    wachthond($extdebug,2, 'notif_staf aangemaakt voor', $notif_staf_new);
                }

                //M61: URGENT TODO Dit zou eigenlijk mee moeten met de parameters params_part maar lijkt op die manier niet te updaten
                if (in_array($ditjaar_pos_leid_kampfunctie, array('hoofdleiding','kernteamlid'))) {
                    $params_part_notif = [
                        'checkPermissions'  => FALSE,
                        'debug' => $apidebug,         
                        'reload'      => TRUE,
                        'where' => [
                            ['id',  '=', $ditevent_part_id],
                        ],
                        'values' => [
                            'PART_LEID_HOOFD.notificatie_deel' => $ditevent_part_notificatie_deel, 
                            'PART_LEID_HOOFD.notificatie_leid' => $ditevent_part_notificatie_leid, 
                            'PART_LEID_HOOFD.notificatie_kamp' => $ditevent_part_notificatie_kamp, 
                            'PART_LEID_HOOFD.notificatie_staf' => $ditevent_part_notificatie_staf,
                        ],
                    ];
                    if ($ditevent_part_id) {
                        wachthond($extdebug,7, 'params_part_notif', $params_part_notif);
                        // M61: TODO staat hier gedisabled: is hij verderop wel enabled? 
                        #$result_part_notif = civicrm_api4('Participant', 'update', $params_part_notif);
                        wachthond($extdebug,9, 'result_part_notif', $result_part_notif);
                    }
                }
    }

    ###################################################################################################
    wachthond($extdebug,1, "########################################################################");
    wachthond($extdebug,1, "### ACL - EINDE ACL CHECK VOOR $displayname $ditjaar_pos_kampfunctie $ditjaar_pos_kampkort", "[cid: $contact_id]");
    wachthond($extdebug,1, "########################################################################");     
    ###################################################################################################

}

function acl_remove_from_group($contactid, $group_array, $group_label) {

    $extdebug = 3;          // 1 = basic // 2 = verbose // 3 = params / 4 = results
    $apidebug = FALSE;
    $extwrite = 1;

    $contact_id     = $contactid;
    $group_array    = $group_array;
    $group_label    = $group_label;

    if ($contact_id AND $group_array) {

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,3, "### ACL - VERWIJDER CID $contact_id UIT GROEPEN $group_label",  $group_array);
        wachthond($extdebug,3, "########################################################################");

        $params_groupcontact_remove = [
            'checkPermissions' => FALSE,
            'debug' => $apidebug,
             'values' => [
                'status' => 'Removed',
            ],
            'where' => [
                ['group_id',    'IN',   $group_array], 
                ['contact_id',  '=',    $contact_id],
            ],
        ];
        wachthond($extdebug,5, 'params_groupcontact_remove',        $params_groupcontact_remove);
        if ($extwrite == 1 AND $group_array) {
            $result_remove = civicrm_api4('GroupContact','update',  $params_groupcontact_remove);
            wachthond($extdebug,1, 'Verwijderd uit ACL groep',      $group_label);
        }
    }

}